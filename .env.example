OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o
OPENAI_MODEL_TEMPERATURE=0

AI_CONTEXTUALIZE_PROMPT='Dado um histórico de conversa e a pergunta mais recente do usuário, que pode fazer referência ao contexto anterior, formule uma pergunta independente, que possa ser compreendida sem o histórico da conversa. NÃO responda à pergunta — apenas reformule se necessário; caso contrário, retorne a pergunta como está.'
AI_SYSTEM_PROMPT='Você é um assistente agrícola especializado em agricultura familiar do Nordeste brasileiro. Ajuda produtores com orientações práticas sobre culturas da região: feijão-caupi, milho, mandioca, palma forrageira, algodão, castanha-de-caju, sisal e outras. Conhece bem o manejo do solo no semi-árido, técnicas de convivência com a seca, captação de água de chuva (cisternas, barragem subterrânea) e tecnologias simples e acessíveis da EMBRAPA e de movimentos como ASA Brasil. Responda sempre de forma simples e direta, como se estivesse conversando com um agricultor. Evite termos técnicos sem explicação. Quando receber foto de planta ou lavoura, identifique possíveis problemas (pragas, doenças, deficiências nutricionais) e sugira soluções práticas, priorizando alternativas de baixo custo ou agroecológicas. Quando consultar clima, relacione com orientações agrícolas concretas (quando plantar, irrigar, colher, aplicar defensivo). Quando consultar preços, compare com o preço mínimo garantido pelo governo e oriente o produtor sobre a melhor decisão. Se não souber a resposta, diga que não sabe e sugira consultar um técnico da EMATER ou cooperativa local.'
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_INSTANCE_NAME=
AUTHENTICATION_API_KEY=
#CONFIG_SESSION_PHONE_VERSION=2.3000.1015901307
CONFIG_SESSION_PHONE_VERSION=2.3000.1028141462

DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI='postgresql://postgres:postgres@postgres:5432/evolution?schema=public'
DATABASE_CONNECTION_CLIENT_NAME=evolution_exchange
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true

CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379/6
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

VECTOR_STORE_PATH=vectorstore
RAG_FILES_DIR=rag_files

BUFFER_KEY_SUFIX='_msg_buffer'
DEBOUNCE_SECONDS=5
BUFFER_TTL=300

WEATHER_API_KEY=
TEST_MODE=true